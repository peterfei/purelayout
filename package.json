{
  "name": "purelayout",
  "version": "0.3.1",
  "description": "Pure JavaScript/TypeScript CSS layout engine — no browser DOM required",
  "author": "peterfei",
  "repository": {
    "type": "git",
    "url": "git@github.com:peterfei/purelayout.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "test:unit": "vitest run --dir tests/unit",
    "test:diff": "vitest run --dir tests/diff",
    "test:diff:capture": "npx tsx tests/diff/capture.ts",
    "lint": "tsc --noEmit",
    "bench": "vitest bench",
    "demo": "npm run demo:flexbox && npm run demo:typography && npm run demo:ui && npm run demo:responsive && npm run demo:dataviz && npm run demo:pretext && npm run demo:multilang",
    "demo:flexbox": "node demos/demo-flexbox.mjs",
    "demo:typography": "node demos/demo-typography.mjs",
    "demo:ui": "node demos/demo-ui-components.mjs",
    "demo:responsive": "node demos/demo-responsive.mjs",
    "demo:dataviz": "node demos/demo-data-viz.mjs",
    "demo:pretext": "node demos/demo-pretext.mjs",
    "demo:multilang": "node demos/demo-multilang.mjs"
  },
  "devDependencies": {
    "playwright": "^1.50.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "optionalDependencies": {
    "@chenglou/pretext": "^0.0.3",
    "canvas": "^3.1.0"
  },
  "peerDependenciesMeta": {
    "canvas": {
      "optional": true
    },
    "@chenglou/pretext": {
      "optional": true
    }
  },
  "license": "MIT",
  "keywords": [
    "css",
    "layout",
    "flexbox",
    "block",
    "inline",
    "ssr",
    "pdf",
    "canvas",
    "typesetting"
  ],
  "dependencies": {
    "pptxgenjs": "^4.0.1"
  }
}
